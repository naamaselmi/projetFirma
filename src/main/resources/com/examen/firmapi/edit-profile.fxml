<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.image.ImageView?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.examen.firmapi.controllers.EditProfileController"
      spacing="10">

    <!-- FIXED PADDING -->
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Edit Profile"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ImageView fx:id="profilePreview"
                   fitHeight="80"
                   fitWidth="80"
                   preserveRatio="true"/>
        <Button text="Choose Picture"
                onAction="#handleChoosePicture"/>
    </HBox>

    <GridPane hgap="10" vgap="10">

        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1" disable="true"/>

        <Label text="Téléphone:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="telephoneField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Adresse:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="adresseField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Ville:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="villeField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Code Postal:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="codePostalField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Pays:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="paysField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="Date de Naissance:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateNaissancePicker" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        <Label text="Genre:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <ComboBox fx:id="genreCombo" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

        <Label text="Bio:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <TextArea fx:id="bioArea"
                  prefRowCount="3"
                  GridPane.rowIndex="10"
                  GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="saveBtn" text="Save"/>
        <Button fx:id="cancelBtn" text="Cancel"/>
    </HBox>

</VBox>