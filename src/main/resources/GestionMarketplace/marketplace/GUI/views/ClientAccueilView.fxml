<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: #fefbde; -fx-background: #fefbde;"
            xmlns="http://javafx.com/javafx/20.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Firma.controllers.GestionMarketplace.ClientAccueilController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="28" style="-fx-background-color: #fefbde;">
         <padding><Insets bottom="40" left="35" right="35" top="25"/></padding>

         <!-- ════════════ HERO HEADER ════════════ -->
         <VBox alignment="CENTER" spacing="6"
               style="-fx-background-color: linear-gradient(to right, #49ad32, #3ba829); -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 12, 0, 0, 4);">
            <padding><Insets bottom="30" left="40" right="40" top="30"/></padding>
            <Label fx:id="lblWelcome" text="Bienvenue sur FIRMA 👋" style="-fx-text-fill: white;">
               <font><Font name="System Bold" size="32"/></font>
            </Label>
            <Label fx:id="lblSubtitle" text="Votre plateforme intégrée de gestion agricole"
                   style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 15;"/>
            <Label fx:id="lblDate" text="" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13;">
               <VBox.margin><Insets top="4"/></VBox.margin>
            </Label>
         </VBox>

         <!-- ════════════ SHORTCUT BUTTONS ════════════ -->
         <HBox fx:id="shortcutRow" alignment="CENTER" spacing="20"/>

         <Separator style="-fx-background-color: #e0e0e0;"/>

         <!-- ════════════ NOS SERVICES ════════════ -->
         <Label text="Nos Services" textFill="#333">
            <font><Font name="System Bold" size="22"/></font>
         </Label>

         <!-- ── Marketplace Service ── -->
         <VBox fx:id="marketServiceBox" spacing="18"
               style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <padding><Insets bottom="25" left="28" right="28" top="25"/></padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
               <StackPane style="-fx-background-color: #e67e22; -fx-background-radius: 10;" prefWidth="40" prefHeight="40">
                  <SVGPath content="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" fill="white" scaleX="1.0" scaleY="1.0"/>
               </StackPane>
               <Label text=" Marketplace" style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
            </HBox>

            <Label text="Votre marketplace agricole complète — achetez, vendez et louez en toute confiance."
                   wrapText="true" style="-fx-font-size: 14; -fx-text-fill: #555;"/>

            <HBox spacing="30">
               <VBox spacing="6">
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Achat d'équipements agricoles" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Location de véhicules et engins" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
               </VBox>
               <VBox spacing="6">
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Location de terrains agricoles" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Gestion de commandes et livraisons" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
               </VBox>
            </HBox>
         </VBox>

         <!-- ── Events Service ── -->
         <VBox fx:id="eventsServiceBox" spacing="18"
               style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <padding><Insets bottom="25" left="28" right="28" top="25"/></padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
               <StackPane style="-fx-background-color: #49ad32; -fx-background-radius: 10;" prefWidth="40" prefHeight="40">
                  <SVGPath content="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z" fill="white" scaleX="1.0" scaleY="1.0"/>
               </StackPane>
               <Label text="Événements" style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: #49ad32;"/>
            </HBox>

            <Label text="Découvrez et participez aux événements agricoles — salons, formations, journées portes ouvertes et plus encore."
                   wrapText="true" style="-fx-font-size: 14; -fx-text-fill: #555;"/>

            <HBox spacing="30">
               <VBox spacing="6">
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Consultez les événements à venir" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Inscription et participation en ligne" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
               </VBox>
               <VBox spacing="6">
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Recevez vos tickets et QR codes" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                     <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#49ad32" scaleX="1.1" scaleY="1.1"/>
                     <Label text="Gérez vos participations facilement" style="-fx-font-size: 13; -fx-text-fill: #444;"/>
                  </HBox>
               </VBox>
            </HBox>
         </VBox>

         <Separator style="-fx-background-color: #e0e0e0;"/>

         <!-- ════════════ CONTACT FOOTER ════════════ -->
         <HBox alignment="CENTER" spacing="40"
               style="-fx-background-color: #49ad32; -fx-background-radius: 15;">
            <padding><Insets bottom="20" left="30" right="30" top="20"/></padding>
            <HBox spacing="10" alignment="CENTER">
               <SVGPath content="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="white" scaleX="1.2" scaleY="1.2"/>
               <Label style="-fx-font-size: 14; -fx-text-fill: white;" text="+216 71 XXX XXX"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER">
               <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="white" scaleX="1.2" scaleY="1.2"/>
               <Label style="-fx-font-size: 14; -fx-text-fill: white;" text="contact@firma.tn"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER">
               <SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="white" scaleX="1.2" scaleY="1.2"/>
               <Label style="-fx-font-size: 14; -fx-text-fill: white;" text="Tunis, Tunisie"/>
            </HBox>
         </HBox>

      </VBox>
   </content>
</ScrollPane>
