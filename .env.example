# ========================================================
# FIRMA Environment Variables Template
# ========================================================
# This is a TEMPLATE showing required environment variables
#
# For Local Development:
# 1. Copy this to .env
# 2. Fill in your actual values
# 3. Load with: export $(cat .env | xargs)
#
# For Production:
# Use your container orchestration (Docker, Kubernetes)
# or system environment to inject these values
# ========================================================

# ==========================================
# Google Maps API Configuration
# ==========================================
GOOGLE_MAPS_API_KEY=REPLACE_WITH_YOUR_GOOGLE_MAPS_API_KEY

# ==========================================
# Hugging Face API Configuration
# ==========================================
HUGGINGFACE_API_TOKEN=REPLACE_WITH_YOUR_HUGGINGFACE_TOKEN

# ==========================================
# Stripe Payment Configuration
# ==========================================
STRIPE_PUBLIC_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLIC_KEY
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# ==========================================
# Database Configuration
# ==========================================
DB_URL=jdbc:mysql://localhost:3306/firma
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_YOUR_DB_PASSWORD
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ==========================================
# Email Configuration (Gmail SMTP)
# ==========================================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=REPLACE_WITH_YOUR_GMAIL_ADDRESS
EMAIL_SMTP_PASSWORD=REPLACE_WITH_YOUR_GMAIL_APP_PASSWORD
EMAIL_FROM_ADDRESS=REPLACE_WITH_YOUR_GMAIL_ADDRESS
EMAIL_FROM_NAME=FIRMA

# ==========================================
# Application Configuration
# ==========================================
APP_NAME=FIRMA Agricultural Management System
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# ==========================================
# Feature Flags
# ==========================================
FEATURE_STRIPE_ENABLED=true
FEATURE_EMAIL_ENABLED=true
FEATURE_MAPS_ENABLED=true
FEATURE_AI_ENABLED=true

